# ── Database ──────────────────────────────────────────────────────────────────
# On Render: injected automatically via render.yaml (fromDatabase)
# For local dev: spin up a local Postgres instance or use a free cloud one
DATABASE_URL=postgresql://user:password@localhost:5432/blameflow

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: azure_openai | anthropic | openai
LLM_PROVIDER=azure_openai

# ── Azure OpenAI (default) ────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Anthropic (alternative) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI (alternative) ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── GitHub ────────────────────────────────────────────────────────────────────
# Optional — raises rate limit from 60 to 5,000 req/hr
GITHUB_TOKEN=ghp_...

# ── App ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
